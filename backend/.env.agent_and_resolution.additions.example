# Database
POSTGRES_URL=postgresql+psycopg2://postgres:change_me@localhost:5432/DataGalaxy_tables

# Existing catalog tables
CATALOG_SOURCE_TABLE=source
CATALOG_CONTAINER_TABLE=container
CATALOG_STRUCTURE_TABLE=structure
CATALOG_FIELD_TABLE=field
DQC_DEFAULT_TABLE=DQC

# Neo4j optional for GraphRAG neighborhood retrieval
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# Chat LLM provider for agents: openai or azure_openai
LLM_PROVIDER=openai
LLM_DISABLE_AZURE_FALLBACK=true
LLM_RUN_MAX_CALLS=20
LLM_MAX_PROMPT_CHARS=8000
LLM_MAX_COMPLETION_TOKENS=700
LLM_REASONING_EFFORT=low
LLM_MIN_SECONDS_BETWEEN_CALLS=0.25
LLM_RAG_OBJECT_ROWS=4
LLM_RAG_RELATIONSHIP_NEIGHBORS=6
LLM_RAG_LINEAGE_EXAMPLES=2
LLM_RAG_SIMILAR_DECISIONS=4
LLM_RAG_SCHEMA_COLUMNS=4
LLM_RAG_PROVENANCE_EVENTS=3

# OpenAI API chat model for migration/DQC agents
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=90

# Optional Azure OpenAI / Azure AI Foundry fallback
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_TIMEOUT_SECONDS=90

# Embeddings
EMBEDDING_DIM=1536
EMBEDDING_PROVIDER=local_hash  # local_hash or azure_openai
EMBEDDING_BATCH_SIZE=128

# DQC agent
DQC_AGENT_MODE=fixed_workflow  # fixed_workflow first, foundry_agent later
DQC_HIGH_CONFIDENCE=85
DQC_MEDIUM_CONFIDENCE=65

# Observability
LOG_LEVEL=INFO
PIPELINE_LOG_TO_DB=true
UPLOAD_DIR=./storage/uploads

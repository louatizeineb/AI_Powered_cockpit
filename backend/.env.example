KAFKA_BOOTSTRAP_SERVERS=localhost:9092
DQC_CONSUMER_GROUP=dqc-event-consumer
DQC_ENVIRONMENT=test
DQC_UPLOAD_MAX_BYTES=26214400
DQC_UPLOAD_CHUNK_BYTES=1048576
DQC_DATABASE_MAX_ROWS=10000

ENABLE_DQC_CATALOG_RESOLUTION=true
ENABLE_DQC_EVENT_KG_WRITES=true
ENABLE_DQC_DLQ_LOGGING=true

EVENT_NEO4J_URI=bolt://127.0.0.1:7688
EVENT_NEO4J_USER=neo4j
EVENT_NEO4J_PASSWORD=change_me

ELASTICSEARCH_URL=http://localhost:9200
DQC_LOG_DIR=logs/dqc

REDIS_URL=redis://localhost:6379/0

# Migration v2 durable orchestration state. Keep this database separate from
# the active application catalog until a graph version is published.
MIGRATION_V2_POSTGRES_URL=postgresql+psycopg2://postgres:change_me@localhost:5432/DataGalaxy_migration_v2
MIGRATION_V2_WORKFLOW_VERSION=1.0.0
MIGRATION_V2_ENV_CONFIG_PATH=configs/migration_v2/local_env.yaml
MIGRATION_V2_CONTRACT_PATH=backend/app/migration_v2/contracts/datagalaxy_athena_v1.yaml

SCHEMA_INTELLIGENCE_NEO4J_URI=bolt://127.0.0.1:7690
SCHEMA_INTELLIGENCE_NEO4J_USER=neo4j
SCHEMA_INTELLIGENCE_NEO4J_PASSWORD=change_me
SCHEMA_INTELLIGENCE_NEO4J_DATABASE=neo4j

LLM_PROVIDER=openai
LLM_DISABLE_AZURE_FALLBACK=true
LLM_RUN_MAX_CALLS=20
LLM_MAX_PROMPT_CHARS=8000
LLM_MAX_COMPLETION_TOKENS=700
LLM_REASONING_EFFORT=low
LLM_MIN_SECONDS_BETWEEN_CALLS=0.25
LLM_RAG_OBJECT_ROWS=4
LLM_RAG_RELATIONSHIP_NEIGHBORS=6
LLM_RAG_LINEAGE_EXAMPLES=2
LLM_RAG_SIMILAR_DECISIONS=4
LLM_RAG_SCHEMA_COLUMNS=4
LLM_RAG_PROVENANCE_EVENTS=3
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=90

# Optional Azure fallback. Leave empty when using direct OpenAI API.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_TIMEOUT_SECONDS=90

LANGSMITH_TRACING=true
LANGSMITH_PROJECT=ai-powered-cockpit
LANGSMITH_API_KEY=lsv2_your_langsmith_key

# Base URL for the AI-Powered Data Quality Cockpit backend API.
# Falls back to http://127.0.0.1:8001 when unset.
VITE_API_BASE_URL=http://127.0.0.1:8001

# Optional: comma-separated list of DQC backends to fan out resolution
# requests across. Defaults to VITE_API_BASE_URL when unset.
# VITE_DQC_API_BASE_URLS=http://127.0.0.1:8001
